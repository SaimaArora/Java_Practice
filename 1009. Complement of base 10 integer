class Solution {
    private int length(int n) {
        int count = 0;
        while(n!=0) {
            n>>=1;
            count++;
        }
        return count;
    }
    public int bitwiseComplement(int n) {
        if(n==0) return 1;
        int len = length(n);
        int mask = (1<<len) - 1;
        return n ^mask;
        
    }
}
