class Solution {
    public int findMinArrowShots(int[][] points) {
        Arrays.sort(points, (a,b)-> Integer.compare(a[1],b[1])); //causes inconsistency in big int
        int n = points.length, count = 0, ind = 0;
        while(ind < n) {
            int curr = points[ind][1];
            while(ind < n && points[ind][0] <= curr) {
                ind++;
            }
            count++;
        }
        return count;
    }
}
