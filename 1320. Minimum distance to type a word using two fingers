class Solution {
    private int distance(int ind1, int ind2) {
        if(ind1 == -1) return 0;
        int r1 = ind1/6, c1 = ind1%6, r2 = ind2/6, c2= ind2%6;
        return Math.abs(r1 - r2) + Math.abs(c1-c2);
    }
    private int recursion(int ind, String word, int other, int[][] memo) {
        if(ind >= word.length()) return 0;
        if(memo[ind][other+1] != -1) return memo[ind][other+1];
        int currChar = word.charAt(ind) -'A';
        int prevChar = (ind == 0) ? -1: word.charAt(ind - 1) -'A';
        int currFinger = (ind==0?0:distance(prevChar, currChar)) + recursion(ind+1, word, other, memo);
        int otherFinger = distance(other, currChar) + recursion(ind+1, word, prevChar, memo);
        return memo[ind][other+1] = Math.min(currFinger, otherFinger);
    }
    public int minimumDistance(String word) {
        int n = word.length();
        int[][] memo = new int[n][27];
        for(int[] r: memo)  Arrays.fill(r, -1);
        return recursion(0, word, -1, memo);
    }
}
