class Solution {
    public int jump(int[] nums) {
        int farthest = nums[0], currEnd = 0, jumps = 0, n = nums.length;
        for(int i = 0; i < n - 1; i++) {
            farthest = Math.max(farthest, nums[i]+i);
            if(i == currEnd) {
                jumps++;
                currEnd = farthest;
            }
        }
        return jumps;
    }
}
