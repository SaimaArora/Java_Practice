class Solution {

    private int totalSubarrays(int[] nums, int k) {
        int count = 0, l = 0, n= nums.length, total = 0;
        HashMap<Integer, Integer> hm = new HashMap<>();
        for(int r = 0; r< n; r++) {
            hm.put(nums[r], hm.getOrDefault(nums[r], 0) + 1);
            while (hm.size() > k) {
                hm.put(nums[l], hm.getOrDefault(nums[l], 0) - 1);
                if(hm.get(nums[l]) == 0) hm.remove(nums[l]);
                l++;
            }
            total+=(r - l + 1);
        }
        return total;
    }

    public int subarraysWithKDistinct(int[] nums, int k) {
        return totalSubarrays(nums, k) - totalSubarrays(nums, k - 1);
    }
}
