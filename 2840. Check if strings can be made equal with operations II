class Solution {
    public boolean checkStrings(String s1, String s2) {
        int[] freqA1 = new int[26];
        int[] freqB1 = new int[26];
        int[] freqA2 = new int[26];
        int[] freqB2 = new int[26];
        int n1 = s1.length(), n2 = s2.length();
        //A -> even B-> odd 
        for(int i = 0; i < n1; i++) {
            if(i%2==0) {
                freqA1[s1.charAt(i)-'a']++;
            } else freqB1[s1.charAt(i) - 'a']++;
        }
        for(int i = 0; i < n2 ; i++) {
            if(i%2 == 0) freqA2[s2.charAt(i)-'a']++;
            else freqB2[s2.charAt(i)-'a']++;
        }
        for(int i = 0; i < 26; i++) {
            if(freqA1[i] != freqA2[i]) return false;
            if(freqB1[i] != freqB2[i]) return false;
        } return true;
    }
}
