class Solution {
    public int countSubmatrices(int[][] grid, int k) {
        int count = 0;
        int n = grid.length, m = grid[0].length;
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < m; j++) {
                //top
                if(i > 0) grid[i][j]+= grid[i - 1][j];
                //left
                if(j > 0) grid[i][j]+=grid[i][j - 1];
                //diagonal
                if(i > 0 && j> 0) grid[i][j] -= grid[i - 1][j - 1];
                if(grid[i][j] <= k) {
                    count++;
                } else break;
            }
        }
        return count;
    }
}
