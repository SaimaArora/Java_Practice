class Solution {
    private int[] computeZArray(String s) {
        int n = s.length();
        int[] z = new int[n];
        int r = 0, l = 0;
        for(int i = 1 ; i < n; i++) {
            //outside
            if(i > r) {
                l = i; r = i;
                while(r < n && s.charAt(r) == s.charAt(r - l)) r++;
                z[i] = r - l;
                r--;
            } else {
                int k = i - l;
                if(z[k] < r - i+1) {
                    z[i] = z[k];
                } else {
                    l = i;
                    while(r < n && s.charAt(r) == s.charAt(r - l)) r++;
                    z[i] = r - l;
                    r--;
                }
            }
        }
        return z;
    }
    public int minStartingIndex(String s, String pattern) {
        int n = s.length();
        int m = pattern.length();
        String s1 = new String(pattern + "$" + s);
        int[] z1 = computeZArray(s1);
        String revs = new StringBuilder(s).reverse().toString();
        String revp = new StringBuilder(pattern).reverse().toString();
        int[] z2 = computeZArray(revp + "$" + revs);
        for(int i = 0; i <= n - m; i++) {
            int pref = z1[m+i+1];
            int suff = z2[m + 1 + (n - i - m)];
            if(pref + suff >= m - 1) return i;
        }
        return -1;
    }
}
