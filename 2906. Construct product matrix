class Solution {
    public int[][] constructProductMatrix(int[][] grid) {
        int mod = 12345, running = 1;
        int n = grid.length, m = grid[0].length;
        int[][] p = new int[n][m];
        for(int i = 0; i < n; i++) {
            for(int j = 0; j < m; j++) {
                p[i][j] = running%mod;
                running = (running*(grid[i][j] % mod))%mod;
            }
        }
        running = 1;
        for(int i = n - 1; i >= 0; i--) {
            for(int j = m - 1; j >= 0; j--) {
                p[i][j] = (p[i][j] * running)%mod;
                running = (running * (grid[i][j]%mod))%mod;
            }
        }
        return p;
    }
}
