class Solution {
    class Train{
        int st;int end;
        Train(int s, int e) {
            st = s;
            end = e;
        }
    }
    public int minPlatform(int arr[], int dep[]) {
        //  code here
        int n = arr.length;
        Train[] tr = new Train[n];
        for(int i = 0; i < n; i++) {
            tr[i] = new Train(arr[i], dep[i]);
        }
        Arrays.sort(tr, (a, b)-> a.st - b.st);
        PriorityQueue<Integer> pq = new PriorityQueue<>();
        for(int i = 0; i < n; i++) {
            if(!pq.isEmpty() && pq.peek()< tr[i].st) {
                pq.poll();
            }
            pq.offer(tr[i].end);
        }
        return pq.size();
    }
}
