class Solution {
    public int minimumDistance(int[] nums) {
        HashMap<Integer, int[]> hm = new HashMap<>();
        int n = nums.length;
        int minDist = Integer.MAX_VALUE;
        for(int i = 0; i < n; i++) {
            if(!hm.containsKey(nums[i])) {
                hm.put(nums[i], new int[]{i, -1, 1});
            } else {
                int[] curr = hm.get(nums[i]);
                curr[2]++; //count increased
                if(curr[2] == 2) {
                    curr[1] = i;
                    
                } else if(curr[2] >= 3) {
                    int x = curr[0], y = curr[1], z = i;
                    int dist = 2*(z - x);
                    minDist = Math.min(minDist, dist);
                    curr[0] = curr[1];
                    curr[1] = i;
                    curr[2]--;
                }
                hm.put(nums[i], curr);
            }
        }
        return minDist == Integer.MAX_VALUE?-1:minDist;
    }
}
