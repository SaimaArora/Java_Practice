class Solution {
    private int recursion(int ind, int[] nums, int[] memo) {
        if(ind >= nums.length - 1) return 0;
        if(memo[ind] != -1) return memo[ind];
        int minJump = 100000, total = 0;
        for(int i = 1; i <= nums[ind]; i++) {
            int curr = recursion(ind+i, nums, memo);
            total = 1+ curr;
            minJump = Math.min(minJump, total);
        }
        return memo[ind] = minJump;
    }
    public int jump(int[] nums) {
        int n = nums.length;
        int[] memo = new int[n];
        Arrays.fill(memo, -1);
        int ans = recursion(0, nums, memo);
        return ans == 100000 ? 0:ans;

    }
}
