class Solution {
    public int numberOfSubmatrices(char[][] g) {
        int n = g.length,m = g[0].length;
        int[][] grid = new int[n][m];
        int[][] xcount = new int[n][m];
        for(int i = 0; i < n; i++) {
            for(int j = 0; j < m; j++) {
                if(g[i][j] == 'X') {grid[i][j] = 1; xcount[i][j] = 1;}
                else if(g[i][j] == 'Y') grid[i][j] = -1;
                else grid[i][j] = 0;
            }
        }
        for(int i =  0; i < n; i++) {
            for(int j = 0; j < m; j++) {
                if(i > 0){ grid[i][j] +=grid[i - 1][j]; xcount[i][j] +=xcount[i - 1][j];}
                if(j > 0){ grid[i][j] += grid[i][j - 1]; xcount[i][j] +=xcount[i][j - 1];}
                if(i>0 && j>0){ grid[i][j] -=grid[i - 1][j - 1]; xcount[i][j] -=xcount[i - 1][j - 1];}
            }
        }
        int ans = 0;
        for(int i = 0; i < n; i++) {
            for(int j = 0; j < m; j++) {
                if(grid[i][j] == 0 && xcount[i][j] > 0) ans++;
            }
        }
        return ans;
    }
}
