class Solution {
    public int snakesAndLadders(int[][] board) {
        int n = board.length;
        int target = n * n;
        int[] dist = new int[target+1];
        Arrays.fill(dist, -1);
        Queue<Integer> q = new LinkedList<>();
        q.offer(1);
        dist[1] = 0;
        while(!q.isEmpty()) {
            int curr = q.poll();
            if(curr == target) return dist[curr];
            int minDist = Math.min(curr+6, target);
            for(int next = curr+1; next <= minDist; next++) {
                int[] coords = getCoordinates(next, n);
                int r = coords[0], c = coords[1];
                int destination = (board[r][c] == -1)? next:board[r][c];
                if(dist[destination] == -1) {
                    dist[destination] = dist[curr] + 1;
                    q.offer(destination);
                }
            }
        }
        return -1;
        
    }
    private int[] getCoordinates(int sq, int n) {
            int curr = sq - 1;
            int rowBottom = curr/n;
            int row = (n - 1) - (curr / n);
            int col = curr % n;
            if (rowBottom % 2 != 0) {
                col = (n - 1) - col;
            }
            return new int[]{row, col};
        }
}
