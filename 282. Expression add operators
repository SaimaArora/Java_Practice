class Solution {
    private void dfs(int index, String path, long curr, long lastValue, String num, int target, List<String> result) {
        if(index >= num.length()) {
            if(curr == target){
                result.add(path);
                return;
            }
            return;
        }
        for(int i = index; i < num.length(); i++) {
            if(i != index && num.charAt(index) == '0') break;
            String part = num.substring(index, i + 1);
            long n = Long.parseLong(part);
            if(index == 0) {
                dfs(i+1, path+part, n, n, num, target, result);
            } else {
                //addition
                dfs(i+1, path+"+"+part, curr+n, n, num, target, result);
                //subtraction
                dfs(i+1, path+"-"+part, curr-n, -n, num, target, result);
                //multiplication
                long newVal = (curr - lastValue) + (lastValue*n);
                dfs(i+1, path+"*"+part, newVal, lastValue*n, num, target, result);
            }
         }
    }
    public List<String> addOperators(String num, int target) {
        List<String> result = new ArrayList<>();
        dfs(0, "", 0l, 0l, num, target, result);
        return result;
    }
}
