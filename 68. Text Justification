class Solution {
    public List<String> fullJustify(String[] words, int maxWidth) {
        List<String> result = new ArrayList<>();
        List<String> currLine = new ArrayList<>();
        int currLen = 0;
        for(String word : words) {
            if(word.length() + currLen + currLine.size()  > maxWidth) {
                result.add(justifyLine(currLine, currLen, maxWidth));

                currLine.clear();
                currLen = 0;
            }
            currLine.add(word);
            currLen+=word.length();
        }
        StringBuilder lastLine = new StringBuilder();
        for(String word: currLine) {
            lastLine.append(word);
            if(lastLine.length() < maxWidth) lastLine.append(" ");
        }
        while(lastLine.length() < maxWidth) {
            lastLine.append(" ");
        }
        result.add(lastLine.toString());
        return result;
    }
    private String justifyLine(List<String> curr, int len, int maxWidth) {
        int n = curr.size();
        StringBuilder str = new StringBuilder();
        int gaps = n - 1;
        if(gaps == 0) {
            str.append(curr.get(0));
            while(str.length() < maxWidth) str.append(" ");
            return str.toString();
        }
        int spaces = (maxWidth - len)/gaps, extra = (maxWidth - len) % gaps, ind = 0;
        while(ind < n) {
            str.append(curr.get(ind));
            int sp = 0;
            int currSp = spaces;
            if(extra > ind) currSp +=1;
            while(str.length() < maxWidth && sp < currSp) {
                str.append(" ");
                sp++;
            }
            ind++;
        }
        while(str.length() < maxWidth) {
            str.append(" ");
        }
        return str.toString();
    }
}
