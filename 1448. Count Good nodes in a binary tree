class Solution {
     int count =0;
    private void dfs(TreeNode root, int maxVal) {
        if(root == null) return;
        if(root.val >= maxVal) {
            count++;
        }
        dfs(root.left, Math.max(root.val, maxVal));
        dfs(root.right, Math.max(root.val, maxVal));
    }
    public int goodNodes(TreeNode root) {
        dfs(root, Integer.MIN_VALUE);
        return count;
    }
}
