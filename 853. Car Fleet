class Solution {
    public class Car{
        int pos, speed;
        Car(int pos, int speed){
            this.pos = pos;
            this.speed = speed;
        }
    }
    class sortCar implements Comparator<Car>{
        public int compare(Car c1, Car c2) {
            return c2.pos - c1.pos;
        }
    }
    public int carFleet(int target, int[] position, int[] speed) {
        TreeMap<Car, Double> tm = new TreeMap<>(new sortCar());
        for (int i = 0; i < position.length; i++) {
            double time = (double)(target - position[i])/speed[i];
            tm.put(new Car(position[i], speed[i]), time);
        }
        double prev = 0.0;
        int ans = 0;
        for(Map.Entry<Car, Double> entry : tm.entrySet()) {
            if(prev == 0.0 || prev < entry.getValue()){
                ans++;
                prev = entry.getValue();
            }
        }
        return ans;
    }
}
