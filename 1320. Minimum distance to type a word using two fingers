class Solution {
    private int distance(int ind1, int ind2) {
        if(ind1 == -1) return 0;
        int r1 = ind1/6, c1 = ind1%6, r2 = ind2/6, c2= ind2%6;
        return Math.abs(r1 - r2) + Math.abs(c1-c2);
    }
    private int recursion(int ind, String word, int f1, int f2, int[][][] memo) {
        if(ind >= word.length()) return 0;
        if(memo[ind][f1+1][f2+1] != -1) return memo[ind][f1+1][f2+1];
        int finger1 = distance(f1, word.charAt(ind) -'A') + recursion(ind+1, word, word.charAt(ind) -'A', f2, memo);
        int finger2 = distance(f2, word.charAt(ind)-'A') + recursion(ind+1, word, f1, word.charAt(ind)-'A', memo);
        return memo[ind][f1+1][f2+1] = Math.min(finger1, finger2);
    }
    public int minimumDistance(String word) {
        int n = word.length();
        int[][][] memo = new int[n][27][27];
        for(int[][] r: memo) for(int[] c: r) Arrays.fill(c, -1);
        return recursion(0, word, -1, -1, memo);
    }
}
