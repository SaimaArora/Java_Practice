public class Codec {

    HashMap<Character, String> table;
    Node root;
    //define node
    class Node{
        char ch;
        int sum;
        Node left, right;
        Node(char ch, int sum) {
            this.ch = ch;
            this.sum = sum;
            this.left = null;
            this.right = null;
        }

    }
    //preorder
    void createTable(Node node, String encode) {
        if(node == null) return;
        if (node.left == null && node.right == null) {
            table.put(node.ch, encode);
            return;
        }
        createTable(node.left, encode + "0");
        createTable(node.right, encode+"1");
    }

    //encode to shorter url - freq, pq
    public String encode(String longUrl) {
        char[] freq = new char[256];
        for(int i = 0; i < longUrl.length(); i++) {
            freq[longUrl.charAt(i)]++;
        }

        table = new HashMap<>();
        PriorityQueue<Node> pq = new PriorityQueue<>((a, b)-> a.sum - b.sum);
        //fill pq
        for(int i = 0; i < 256; i++) {
            if(freq[i] > 0) {
                pq.offer(new Node((char)i, freq[i]));
            }
        }
        root = null;

        while(pq.size() > 1) {
            Node left = pq.poll();
            Node right = pq.poll();
            Node temp = new Node('\u0000', left.sum+right.sum);
            temp.left = left; temp.right = right;
            pq.offer(temp);
        }
        root = pq.poll();
        createTable(root, "");
        StringBuilder url = new StringBuilder("https://tinyurl.com/");
        for (int i = 0; i < longUrl.length(); i++) {
            char c = longUrl.charAt(i);
            url.append(table.get(c));
        }
        return url.toString();
    }


    // Decodes a shortened URL to its original URL.
    public String decode(String shortUrl) {
        StringBuilder res = new StringBuilder();

        for(int i = 20; i < shortUrl.length();)  {
            Node curr = root;
            while(curr.left != null && curr.right != null) {
                if (shortUrl.charAt(i) == '0') {
                    curr = curr.left;
                }
                else {
                    curr = curr.right;
                }
                i++;
            }
            res.append(curr.ch);
        }
        return res.toString();
    }
}

