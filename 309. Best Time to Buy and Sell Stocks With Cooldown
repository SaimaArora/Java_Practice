class Solution {
    private int recursion(int ind, boolean buy, int[] prices) {
        if(ind >= prices.length) return 0;
        if(buy) {
            int take = -prices[ind] + recursion(ind+1,false, prices);
            return Math.max(take, recursion(ind+1, buy, prices));
        } else {
            int sell = prices[ind]+recursion(ind+2, true, prices);
            return Math.max(recursion(ind+1, false, prices), sell);
        }
    }
    private int memo(int ind, int buy, int[] prices, int[][] dp) {
        if(ind >= prices.length) return 0;
        if(buy == 1) {
            int take = -prices[ind] + memo(ind+1,0, prices, dp);
            return dp[ind][buy] = Math.max(take, memo(ind+1, 1, prices, dp));
        } else {
            int sell = prices[ind]+memo(ind+2, 1, prices, dp);
            return dp[ind][buy] = Math.max(memo(ind+1, 0, prices, dp), sell);
        }
    }
    public int maxProfit(int[] prices) {
        int[][] dp = new int[prices.length][2];
        for(int[] arr: dp) Arrays.fill(arr, -1);
        return memo(0, 1, prices, dp);
    }
}
