class Solution {
    public boolean canPartitionGrid(int[][] grid) {
        int n =grid.length, m = grid[0].length;
        long total = 0l;
        for(int r = 0; r < n; r++) {
            for(int j = 0; j < m; j++ ) {
                total+=(long)grid[r][j];
            }
        }
        if(total %2 != 0) return false;
        long target = total/2;
        long sum = 0l;
        for(int i = 0; i < n; i++) {
            for(int j = 0; j < m; j++) {
                sum+=grid[i][j];
            }
            if(sum == target) return true;
            if(sum > target) break;
        }
        sum = 0;
        for(int j = 0; j < m; j++) {
            for(int i = 0; i < n; i++) {
                sum+=grid[i][j];
            }
            if(sum == target) return true;
            if(sum > target) break;
        }
        return false;
    }
}
